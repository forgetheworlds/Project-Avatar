# =============================================================================
# Mark4 7" 6S 1500kV — PX4 Parameter Overlay
# =============================================================================
# Airframe: Custom 7-inch quadcopter for aerial filming
# Hardware: Mark4 frame, 6S LiPo, 1500kV motors, Pixhawk 6X
#
# This file contains minimum safety + offboard overlay parameters.
# Values are typical starting points - TUNE AFTER BENCH TESTING.
#
# Usage:
#   1. Flash firmware: ./flash-px4.sh --airframe mark4_7in
#   2. Apply params: Use QGroundControl or MAVSDK param upload
#   3. Verify: python hardware/px4/preflight.py --airframe mark4_7in
#   4. Tune: Adjust PID and rates after bench/hover tests
#
# Format: PX4 parameter file syntax (QGC-compatible)
#   param set-default <NAME> <VALUE>
# =============================================================================

# -----------------------------------------------------------------------------
# AIRFRAME SELECTION
# -----------------------------------------------------------------------------
# SYS_AUTOSTART: Airframe ID (defines mixer, motor order, default PIDs)
# 4001 = Generic 10" quad (closest match, will need PID tuning)
# Alternative: Create custom airframe if motor layout differs
param set-default SYS_AUTOSTART 4001

# -----------------------------------------------------------------------------
# OFFBOARD FAILSAFE (Layer 1 - CRITICAL FOR LLM CONTROL)
# -----------------------------------------------------------------------------
# COM_OBL_RC_ACT: Action when offboard commands stop
#   0 = disabled (DANGEROUS)
#   1 = Hold (hover in place)
#   2 = Land (descend immediately)
#   3 = RTL (Return to Launch) — RECOMMENDED for filming
param set-default COM_OBL_RC_ACT 3

# COM_OF_LOSS_T: Timeout before offboard failsafe triggers (seconds)
#   0.5s = responsive but allows minor latency spikes
#   Lower = faster response but more false triggers
#   Higher = slower response, more drift time
param set-default COM_OF_LOSS_T 0.5

# -----------------------------------------------------------------------------
# DISARM AND ARMING SAFETY
# -----------------------------------------------------------------------------
# COM_DISARM_PRFLT: Auto-disarm after landing (seconds)
#   15s = reasonable delay to confirm stable landing
#   Set to 0 to disable (requires manual disarm)
param set-default COM_DISARM_PRFLT 15

# -----------------------------------------------------------------------------
# NAVIGATION FAILSAFE ACTIONS
# -----------------------------------------------------------------------------
# NAV_DLL_ACT: Data link loss action (telemetry connection)
#   0 = disabled
#   1 = Hold
#   2 = RTL — RECOMMENDED (return home on ground station disconnect)
param set-default NAV_DLL_ACT 2

# NAV_RCL_ACT: RC loss action (pilot radio)
#   0 = disabled
#   1 = Hold
#   2 = RTL — RECOMMENDED
param set-default NAV_RCL_ACT 2

# COM_RCL_EXCEPT: RC loss exceptions (bitmask)
#   Bit 2 (value 4) = ignore RC loss when in OFFBOARD mode
#   CRITICAL: Allows autonomous flight without RC link
#   Safety pilot can still take over via mode switch
param set-default COM_RCL_EXCEPT 4

# -----------------------------------------------------------------------------
# BATTERY FAILSAFE (6S LiPo Configuration)
# -----------------------------------------------------------------------------
# BAT_N_CELLS: Number of battery cells
#   6 = 6S LiPo (22.2V nominal, 25.2V max)
param set-default BAT_N_CELLS 6

# BAT_CAPACITY: Battery capacity in mAh
#   Match to actual battery (1500mAh typical for 7" builds)
#   Used for time-to-empty estimation
param set-default BAT_CAPACITY 1500

# BAT_LOW_THR: Low battery warning threshold (0-1 ratio)
#   0.25 = 25% remaining — WARNING LEVEL
#   Ground station should alert, consider RTL soon
param set-default BAT_LOW_THR 0.25

# BAT_CRIT_THR: Critical battery threshold
#   0.15 = 15% remaining — ACTION REQUIRED
#   May trigger automatic landing/RTL
param set-default BAT_CRIT_THR 0.15

# BAT_EMERGEN_THR: Emergency battery threshold
#   0.10 = 10% remaining — IMMINENT POWER LOSS
#   Last resort, land immediately
param set-default BAT_EMERGEN_THR 0.10

# -----------------------------------------------------------------------------
# GEOFENCE (SPATIAL BOUNDARIES)
# -----------------------------------------------------------------------------
# GF_ACTION: Geofence breach action
#   0 = warning only (no enforcement)
#   1 = Hold (hover at boundary)
#   2 = Land (descend at breach point)
#   3 = RTL (Return to Launch) — RECOMMENDED for filming
param set-default GF_ACTION 2

# GF_MAX_HOR_DIST: Maximum horizontal distance from home (meters)
#   500m = ~1640ft radius
#   Large enough for cinematic shots
#   Small enough to contain flyaways
param set-default GF_MAX_HOR_DIST 500

# GF_MAX_VER_DIST: Maximum altitude above home (meters)
#   150m = ~492ft
#   FAA Part 107: 400ft AGL (adjust for terrain)
#   Set higher than legal limit for safety margin
param set-default GF_MAX_VER_DIST 150

# -----------------------------------------------------------------------------
# TUNING — RATE CONTROL (Adjust after bench tests)
# -----------------------------------------------------------------------------
# MC_ROLLRATE_P: Roll rate P-gain
#   0.15 = typical starting point for 7" builds
#   Tune: Increase until oscillation, then back off 10%
param set-default MC_ROLLRATE_P 0.15

# Note: Additional PID params (PITCHRATE_P, YAWRATE_P, etc.)
# should be tuned after initial flight testing.
# See PX4 MC PID Tuning Guide: https://docs.px4.io/main/en/config_mc/

# -----------------------------------------------------------------------------
# ADDITIONAL FAILSAFE PARAMETERS (Required by preflight verification)
# -----------------------------------------------------------------------------
# COM_OBL_ACT: Offboard loss action when no RC available
#   1 = Hold (hover in place when offboard lost, no RC)
param set-default COM_OBL_ACT 1

# COM_RC_LOSS_T: RC loss timeout before failsafe (seconds)
#   0.5s = quick response to signal loss
param set-default COM_RC_LOSS_T 0.5

# COM_LOW_BAT_ACT: Low battery action
#   2 = RTL (Return to Launch on low battery)
param set-default COM_LOW_BAT_ACT 2

# COM_ARM_BAT_MIN: Minimum battery to arm (ratio 0-1)
#   0.4 = 40% minimum to arm (prevent takeoff with low battery)
param set-default COM_ARM_BAT_MIN 0.4

# GF_ALTMODE: Geofence altitude mode
#   0 = Geofence altitude relative to home
param set-default GF_ALTMODE 0

# COM_DL_LOSS_T: Data link loss timeout (seconds)
#   5.0s = allow brief telemetry interruptions
param set-default COM_DL_LOSS_T 5.0
