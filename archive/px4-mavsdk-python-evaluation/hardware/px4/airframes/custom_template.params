# =============================================================================
# Custom Airframe Template — PX4 Parameter Overlay
# =============================================================================
#
# This is a template for creating custom airframe parameter overlays.
# Copy this file, rename it to match your airframe, and fill in values.
#
# INSTRUCTIONS:
#   1. Copy to: hardware/px4/airframes/<your_airframe>.params
#   2. Fill in all sections below
#   3. Remove or adjust comments as needed
#   4. Run preflight check: python hardware/px4/preflight.py --airframe <your_airframe>
#
# Each parameter shows:
#   - Range: Valid values accepted by PX4
#   - Recommended start: Good starting point for tuning
#   - Description: What the parameter controls
#
# Reference: https://docs.px4.io/main/en/advanced_config/parameter_reference.html
# =============================================================================

# -----------------------------------------------------------------------------
# AIRFRAME SELECTION
# -----------------------------------------------------------------------------
# SYS_AUTOSTART: Airframe ID
#   Range: 1-9999 (see PX4 airframe reference)
#   Recommended start: 4001 (Generic Quad) for custom builds
#   Description: Defines mixer, motor order, and default PID values
#   Required: YES
# param set-default SYS_AUTOSTART <VALUE>

# -----------------------------------------------------------------------------
# OFFBOARD FAILSAFE (CRITICAL FOR LLM/AUTONOMOUS CONTROL)
# -----------------------------------------------------------------------------
# COM_OBL_RC_ACT: Action when offboard commands stop
#   Range: 0-3
#   Values: 0=disabled, 1=Hold, 2=Land, 3=RTL
#   Recommended start: 3 (RTL)
#   Description: Determines drone behavior when MAVSDK commands stop
#   Required: YES
# param set-default COM_OBL_RC_ACT <VALUE>

# COM_OF_LOSS_T: Offboard timeout (seconds)
#   Range: 0.1-10.0
#   Recommended start: 0.5
#   Description: How long to wait for commands before failsafe
#   Required: YES
# param set-default COM_OF_LOSS_T <VALUE>

# -----------------------------------------------------------------------------
# DISARM AND ARMING
# -----------------------------------------------------------------------------
# COM_DISARM_PRFLT: Auto-disarm after landing (seconds)
#   Range: 0-20
#   Recommended start: 15
#   Description: Automatically disarms motors after landing
#   Required: NO (defaults to 0 = disabled)
# param set-default COM_DISARM_PRFLT <VALUE>

# -----------------------------------------------------------------------------
# NAVIGATION FAILSAFE
# -----------------------------------------------------------------------------
# NAV_DLL_ACT: Data link loss action
#   Range: 0-4
#   Values: 0=disabled, 1=Hold, 2=RTL, 3=Land, 4=Terminate
#   Recommended start: 2 (RTL)
#   Description: Action when telemetry connection is lost
#   Required: YES
# param set-default NAV_DLL_ACT <VALUE>

# NAV_RCL_ACT: RC loss action
#   Range: 0-4
#   Values: Same as NAV_DLL_ACT
#   Recommended start: 2 (RTL)
#   Description: Action when RC radio link is lost
#   Required: YES
# param set-default NAV_RCL_ACT <VALUE>

# COM_RCL_EXCEPT: RC loss exceptions (bitmask)
#   Range: 0-255
#   Values: Bit 2 (4) = ignore RC loss in OFFBOARD
#   Recommended start: 4 (allows autonomous without RC)
#   Description: When to ignore RC failsafe
#   Required: YES for autonomous flight
# param set-default COM_RCL_EXCEPT <VALUE>

# -----------------------------------------------------------------------------
# BATTERY FAILSAFE
# -----------------------------------------------------------------------------
# BAT_N_CELLS: Number of battery cells
#   Range: 1-12
#   Values: 3S=3, 4S=4, 6S=6
#   Description: Battery cell count for voltage monitoring
#   Required: YES for battery monitoring
# param set-default BAT_N_CELLS <VALUE>

# BAT_CAPACITY: Battery capacity (mAh)
#   Range: 100-50000
#   Description: Used for time-to-empty estimation
#   Required: NO (but recommended)
# param set-default BAT_CAPACITY <VALUE>

# BAT_LOW_THR: Low battery warning threshold
#   Range: 0.0-1.0
#   Recommended start: 0.25 (25%)
#   Description: Warning level, not action
#   Required: YES
# param set-default BAT_LOW_THR <VALUE>

# BAT_CRIT_THR: Critical battery threshold
#   Range: 0.0-1.0
#   Recommended start: 0.15 (15%)
#   Description: Triggers automatic action
#   Required: YES
# param set-default BAT_CRIT_THR <VALUE>

# BAT_EMERGEN_THR: Emergency battery threshold
#   Range: 0.0-1.0
#   Recommended start: 0.10 (10%)
#   Description: Imminent power loss
#   Required: YES
# param set-default BAT_EMERGEN_THR <VALUE>

# -----------------------------------------------------------------------------
# GEOFENCE (SPATIAL BOUNDARIES)
# -----------------------------------------------------------------------------
# GF_ACTION: Geofence breach action
#   Range: 0-4
#   Values: 0=warning, 1=Hold, 2=Land, 3=RTL, 4=Terminate
#   Recommended start: 2 or 3
#   Description: What happens when drone leaves fenced area
#   Required: YES
# param set-default GF_ACTION <VALUE>

# GF_MAX_HOR_DIST: Max horizontal distance from home (meters)
#   Range: 1-10000
#   Recommended start: 500 (500m radius)
#   Description: Horizontal geofence radius
#   Required: YES for geofence
# param set-default GF_MAX_HOR_DIST <VALUE>

# GF_MAX_VER_DIST: Max altitude above home (meters)
#   Range: 1-10000
#   Recommended start: 120 (FAA limit) or 150 (safety margin)
#   Description: Altitude ceiling
#   Required: YES for geofence
# param set-default GF_MAX_VER_DIST <VALUE>

# -----------------------------------------------------------------------------
# TUNING — RATE CONTROL (Adjust after flight testing)
# -----------------------------------------------------------------------------
# MC_ROLLRATE_P: Roll rate P-gain
#   Range: 0.0-1.0
#   Recommended start: 0.10-0.20
#   Description: Proportional gain for roll rate control
#   Required: NO (uses airframe defaults)
# param set-default MC_ROLLRATE_P <VALUE>

# MC_PITCHRATE_P: Pitch rate P-gain
#   Range: 0.0-1.0
#   Recommended start: Same as roll rate
#   Description: Proportional gain for pitch rate control
#   Required: NO
# param set-default MC_PITCHRATE_P <VALUE>

# MC_YAWRATE_P: Yaw rate P-gain
#   Range: 0.0-1.0
#   Recommended start: 0.15-0.25
#   Description: Proportional gain for yaw rate control
#   Required: NO
# param set-default MC_YAWRATE_P <VALUE>

# -----------------------------------------------------------------------------
# CUSTOM TUNING NOTES
# -----------------------------------------------------------------------------
# Add any custom notes about your specific setup here:
# - Motor/prop combination
# - Frame size and weight
# - Known issues or quirks
# - Tuning observations from flight tests
