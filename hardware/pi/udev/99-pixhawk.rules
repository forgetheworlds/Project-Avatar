# Avatar Drone - Pixhawk USB/Serial Rules
#
# These rules create stable symlinks for Pixhawk flight controllers
# and set appropriate permissions for the avatar user.

# FTDI USB-Serial cables (common for Pixhawk TELEM ports)
# Standard FTDI 232R/232H cables
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", SYMLINK+="pixhawk", MODE="0660", GROUP="dialout"
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", SYMLINK+="ftdi_telem%n", MODE="0660", GROUP="dialout"

# FTDI 2232/2232H (dual port)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6010", SYMLINK+="pixhawk%n", MODE="0660", GROUP="dialout"

# FTDI 4232/4232H (quad port)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6011", SYMLINK+="pixhawk%n", MODE="0660", GROUP="dialout"

# Pixhawk with native USB (STM32)
# Common vendor IDs used by various Pixhawk variants
SUBSYSTEM=="tty", ATTRS{idVendor}=="26ac", SYMLINK+="pixhawk", MODE="0660", GROUP="dialout"
SUBSYSTEM=="tty", ATTRS{idVendor}=="26ac", ATTRS{idProduct}=="0010", SYMLINK+="pixhawk4", MODE="0660", GROUP="dialout"
SUBSYSTEM=="tty", ATTRS{idVendor}=="26ac", ATTRS{idProduct}=="0011", SYMLINK+="pixhawk4_mini", MODE="0660", GROUP="dialout"

# Holybro Pixhawk variants
SUBSYSTEM=="tty", ATTRS{idVendor}=="2dae", SYMLINK+="pixhawk", MODE="0660", GROUP="dialout"

# CubePilot / Hex Cube
SUBSYSTEM=="tty", ATTRS{idVendor}=="2dae", ATTRS{idProduct}=="0101", SYMLINK+="cubepilot", MODE="0660", GROUP="dialout"

# Raspilot
SUBSYSTEM=="tty", ATTRS{idVendor}=="2dae", ATTRS{idProduct}=="0100", SYMLINK+="raspilot", MODE="0660", GROUP="dialout"

# Serial ports by path (fallback)
# These create symlinks based on physical USB port position
SUBSYSTEM=="tty", KERNELS=="*-1.2:1.0", SYMLINK+="pixhawk_usb0", MODE="0660", GROUP="dialout"
SUBSYSTEM=="tty", KERNELS=="*-1.3:1.0", SYMLINK+="pixhawk_usb1", MODE="0660", GROUP="dialout"

# GPIO UART (Raspberry Pi serial ports)
# /dev/serial0 -> /dev/ttyAMA0 (mini-UART) or /dev/ttyS0 (PL011)
# These are handled by raspi-config and already have dialout group access
# Add explicit symlink for clarity
SUBSYSTEM=="tty", KERNEL=="ttyAMA0", SYMLINK+="pi_serial", MODE="0660", GROUP="dialout"
SUBSYSTEM=="tty", KERNEL=="ttyS0", SYMLINK+="pi_uart", MODE="0660", GROUP="dialout"

# Notify systemd-udevd about new devices (optional, for device-dependent services)
# ACTION=="add", SUBSYSTEM=="tty", RUN+="/bin/systemctl --no-block try-restart avatar-mavlink-bridge.service"
