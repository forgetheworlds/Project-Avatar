# =============================================================================
# PX4 X500 v2 Kit — PX4 Parameter Overlay
# =============================================================================
# Airframe: PX4 Development Kit X500 v2
# Hardware: X500 frame, 10" props, 4S LiPo, Pixhawk 4
#
# This configuration is designed for SITL/Gazebo simulation testing.
# Matches the gz_x500 model used in Project Avatar simulation stack.
#
# Usage:
#   1. Flash firmware: ./flash-px4.sh --airframe x500_v2
#   2. Apply params: Use QGroundControl or MAVSDK param upload
#   3. Verify: python hardware/px4/preflight.py --airframe x500_v2
#   4. For SITL: Parameters are auto-loaded from simulation config
#
# Format: PX4 parameter file syntax (QGC-compatible)
#   param set-default <NAME> <VALUE>
# =============================================================================

# -----------------------------------------------------------------------------
# AIRFRAME SELECTION
# -----------------------------------------------------------------------------
# SYS_AUTOSTART: Airframe ID
# 4011 = X500 Generic Quad (placeholder - verify against PX4 airframe list)
# Alternative: 4001 Generic Quad if 4011 not available
# For SITL: Usually auto-selected based on simulation model
param set-default SYS_AUTOSTART 4011

# -----------------------------------------------------------------------------
# OFFBOARD FAILSAFE (Layer 1 - CRITICAL FOR LLM CONTROL)
# -----------------------------------------------------------------------------
# COM_OBL_RC_ACT: Action when offboard commands stop
#   3 = RTL (Return to Launch) — RECOMMENDED for safety
param set-default COM_OBL_RC_ACT 3

# COM_OF_LOSS_T: Timeout before offboard failsafe triggers (seconds)
#   0.5s = responsive to communication loss
param set-default COM_OF_LOSS_T 0.5

# -----------------------------------------------------------------------------
# DISARM AND ARMING SAFETY
# -----------------------------------------------------------------------------
# COM_DISARM_PRFLT: Auto-disarm after landing (seconds)
#   15s = reasonable delay for simulation
param set-default COM_DISARM_PRFLT 15

# -----------------------------------------------------------------------------
# NAVIGATION FAILSAFE ACTIONS
# -----------------------------------------------------------------------------
# NAV_DLL_ACT: Data link loss action
#   2 = RTL — return home on telemetry disconnect
param set-default NAV_DLL_ACT 2

# NAV_RCL_ACT: RC loss action
#   2 = RTL — return home on radio disconnect
param set-default NAV_RCL_ACT 2

# COM_RCL_EXCEPT: RC loss exceptions (bitmask)
#   4 = ignore RC loss when in OFFBOARD mode
#   Required for autonomous operation without safety pilot RC
param set-default COM_RCL_EXCEPT 4

# -----------------------------------------------------------------------------
# BATTERY FAILSAFE (4S LiPo Configuration - Simulation Defaults)
# -----------------------------------------------------------------------------
# BAT_N_CELLS: Number of battery cells
#   4 = 4S LiPo (14.8V nominal, 16.8V max)
param set-default BAT_N_CELLS 4

# BAT_CAPACITY: Battery capacity in mAh
#   5000mAh typical for X500 kit
param set-default BAT_CAPACITY 5000

# BAT_LOW_THR: Low battery warning threshold (0-1 ratio)
#   0.25 = 25% remaining
param set-default BAT_LOW_THR 0.25

# BAT_CRIT_THR: Critical battery threshold
#   0.15 = 15% remaining
param set-default BAT_CRIT_THR 0.15

# BAT_EMERGEN_THR: Emergency battery threshold
#   0.10 = 10% remaining
param set-default BAT_EMERGEN_THR 0.10

# -----------------------------------------------------------------------------
# GEOFENCE (SPATIAL BOUNDARIES)
# -----------------------------------------------------------------------------
# GF_ACTION: Geofence breach action
#   2 = Land (safer for populated test areas)
#   Alternative: 3 = RTL
param set-default GF_ACTION 2

# GF_MAX_HOR_DIST: Maximum horizontal distance from home (meters)
#   500m = matches Mark4 for consistent testing
param set-default GF_MAX_HOR_DIST 500

# GF_MAX_VER_DIST: Maximum altitude above home (meters)
#   150m = matches Mark4 for consistent testing
param set-default GF_MAX_VER_DIST 150

# -----------------------------------------------------------------------------
# TUNING — RATE CONTROL
# -----------------------------------------------------------------------------
# MC_ROLLRATE_P: Roll rate P-gain
#   0.15 = typical for 10" props
param set-default MC_ROLLRATE_P 0.15

# -----------------------------------------------------------------------------
# ADDITIONAL FAILSAFE PARAMETERS (Required by preflight verification)
# -----------------------------------------------------------------------------
# COM_OBL_ACT: Offboard loss action when no RC available
#   1 = Hold (hover in place when offboard lost, no RC)
param set-default COM_OBL_ACT 1

# COM_RC_LOSS_T: RC loss timeout before failsafe (seconds)
#   0.5s = quick response to signal loss
param set-default COM_RC_LOSS_T 0.5

# COM_LOW_BAT_ACT: Low battery action
#   2 = Land on low battery
param set-default COM_LOW_BAT_ACT 2

# COM_ARM_BAT_MIN: Minimum battery to arm (ratio 0-1)
#   0.4 = 40% minimum to arm (prevent takeoff with low battery)
param set-default COM_ARM_BAT_MIN 0.4

# GF_ALTMODE: Geofence altitude mode
#   0 = Geofence altitude relative to home
param set-default GF_ALTMODE 0

# COM_DL_LOSS_T: Data link loss timeout (seconds)
#   5.0s = allow brief telemetry interruptions
param set-default COM_DL_LOSS_T 5.0
